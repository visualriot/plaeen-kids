rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ID Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Relational Helpers
    function getParentDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isParentOf(childId) {
      return isSignedIn() && 
             getParentDoc().get('role', '') == 'parent' && 
             getParentDoc().get('linkedKids', []).hasAny([childId]);
    }

    function isGroupMember(groupId) {
      let group = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return isSignedIn() && (
        group.members.hasAny([request.auth.uid]) ||
        group.get('parentIds', []).hasAny([request.auth.uid]) ||
        (getParentDoc().get('role', '') == 'parent' && group.members.hasAny(getParentDoc().get('linkedKids', [])))
      );
    }

    function isGroupAdmin(groupId) {
      let group = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return isSignedIn() && (
        group.ownerId == request.auth.uid ||
        group.get('adminIds', []).hasAny([request.auth.uid]) ||
        isParentOf(group.ownerId)
      );
    }

    // --- Entity Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['parent', 'kid'] &&
             (!data.keys().hasAny(['availability']) || data.availability is map) &&
             (!data.keys().hasAny(['screenTime']) || data.screenTime is map);
    }

    function isValidSession(data) {
      let hasScheduleDetails = data.keys().hasAll(['startTime', 'duration']) &&
                               data.startTime is timestamp &&
                               data.duration is number &&
                               data.duration > 0;
      let isProposal = data.status == 'proposed';

      return data.keys().hasAll(['gameName', 'status', 'proposedBy']) &&
             data.gameName is string && data.gameName.size() <= 200 &&
             data.proposedBy is string &&
             data.status in ['proposed', 'scheduled', 'ongoing', 'completed', 'cancelled'] &&
             (!data.keys().hasAny(['groupId']) || isValidId(data.groupId)) &&
             (!data.keys().hasAny(['gameId']) || isValidId(data.gameId)) &&
             (!data.keys().hasAny(['gameImage']) || data.gameImage is string) &&
             (!data.keys().hasAny(['responses']) || data.responses is map) &&
             (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp) &&
             (!data.keys().hasAny(['endTime']) || data.endTime is timestamp) &&
             (isProposal || hasScheduleDetails);
    }

    function isValidGroupGame(data) {
      return data.keys().hasAll(['name', 'image', 'description', 'platforms', 'genres', 'addedBy']) &&
             data.name is string && data.name.size() <= 200 &&
             data.image is string &&
             data.description is string &&
             data.platforms is list &&
             data.genres is list &&
             (data.addedBy == request.auth.uid || isParentOf(data.addedBy)) &&
             (!data.keys().hasAny(['addedByName']) || data.addedByName is string) &&
             (!data.keys().hasAny(['slug']) || data.slug is string) &&
             (!data.keys().hasAny(['rating']) || data.rating is number) &&
             (!data.keys().hasAny(['releaseDate']) || data.releaseDate is string) &&
             (!data.keys().hasAny(['isChildFriendly']) || data.isChildFriendly is bool) &&
             (!data.keys().hasAny(['minAge']) || data.minAge == null || data.minAge is number) &&
             (!data.keys().hasAny(['teamGoals']) || data.teamGoals is list) &&
             (!data.keys().hasAny(['teamNotes']) || data.teamNotes is string) &&
             (!data.keys().hasAny(['addedAt']) || data.addedAt is timestamp);
    }

    function isValidGroupGameCollaborationUpdate(data) {
      return (!data.keys().hasAny(['teamGoals']) || data.teamGoals is list) &&
             (!data.keys().hasAny(['teamNotes']) || data.teamNotes is string);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isParentOf(userId) || 
                     (isSignedIn() && existing().get('parentId', '') == request.auth.uid);
      
      allow create: if isSignedIn() && isValidUser(incoming()) && isOwner(userId);
      
      allow update: if isSignedIn() && (
        // Action: Update Availability
        (isValidUser(incoming()) && (isOwner(userId) || isParentOf(userId)) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['availability', 'displayName', 'photoURL', 'screenTime', 'friends', 'allowedGames', 'teamAliases']))
      );
    }

    match /users_public/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isOwner(userId) || isParentOf(userId));
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (isOwner(existing().fromId) || isOwner(existing().toId) || isParentOf(existing().fromId) || isParentOf(existing().toId));
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow update, delete: if isSignedIn() && (isOwner(existing().fromId) || isOwner(existing().toId));
    }

    match /groups/{groupId} {
      allow read: if isSignedIn() && (existing().isPublic == true || isGroupMember(groupId));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isGroupAdmin(groupId) || isGroupMember(groupId));
      allow delete: if isSignedIn() && isGroupAdmin(groupId);

      match /sessions/{sessionId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow create: if isSignedIn() && isGroupMember(groupId) && isValidSession(incoming());
        allow update: if isSignedIn() && isGroupMember(groupId) && isValidSession(incoming()) && (
          // Action: Accept/Reject
          incoming().diff(existing()).affectedKeys().hasOnly(['responses', 'participants']) ||
          // Action: Admin Edit
          isGroupAdmin(groupId)
        );
        allow delete: if isSignedIn() && isGroupAdmin(groupId);
      }

      match /games/{gameId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow create: if isSignedIn() && isGroupMember(groupId) && isValidGroupGame(incoming());
        allow update: if isSignedIn() && (
          isGroupAdmin(groupId) ||
          (
            isGroupMember(groupId) &&
            incoming().diff(existing()).affectedKeys().hasOnly(['teamGoals', 'teamNotes']) &&
            isValidGroupGameCollaborationUpdate(incoming())
          )
        );
        allow delete: if isSignedIn() && isGroupAdmin(groupId);
      }

      match /events/{eventId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow create: if isSignedIn();
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isParentOf(existing().userId));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isOwner(existing().userId) || isParentOf(existing().userId));
    }

    match /approvals/{approvalId} {
      allow read: if isSignedIn() && (isOwner(existing().childId) || isOwner(existing().parentId) || isParentOf(existing().childId));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isOwner(existing().parentId) || isParentOf(existing().childId));
    }
  }
}
