rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParentOf(childId) {
      return isAuthenticated() && 
             childId != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'parent' && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('linkedKids', []).hasAny([childId]);
    }

    function isGroupAdmin(groupData) {
      return isAuthenticated() && (
        request.auth.uid == groupData.ownerId || 
        groupData.get('adminIds', []).hasAny([request.auth.uid]) ||
        groupData.get('parentIds', []).hasAny([request.auth.uid]) ||
        isParentOf(groupData.ownerId)
      );
    }

    function isGroupAdminById(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId)) && 
             isGroupAdmin(get(/databases/$(database)/documents/groups/$(groupId)).data);
    }

    function isGroupMember(groupData) {
      return isAuthenticated() && (
        groupData.members.hasAny([request.auth.uid]) || 
        groupData.get('pendingMembers', []).hasAny([request.auth.uid]) ||
        groupData.get('parentIds', []).hasAny([request.auth.uid]) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'parent' && 
         groupData.members.hasAny(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('linkedKids', [])))
      );
    }

    // Collection Rules
    match /users/{userId} {
      // Allow parents to see their children via direct ID (isParentOf) or via query (parentId filter)
      allow read: if isOwner(userId) || 
                     isParentOf(userId) || 
                     (isAuthenticated() && resource.data.get('parentId', '') == request.auth.uid);
      
      allow update: if isOwner(userId) || isParentOf(userId);
      allow create: if isAuthenticated();
    }

    match /users_public/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isOwner(userId) || isParentOf(userId));
    }

    match /friendRequests/{requestId} {
      allow read, update, delete: if isAuthenticated() && 
                                    (request.auth.uid == resource.data.fromId || 
                                     request.auth.uid == resource.data.toId || 
                                     isParentOf(resource.data.fromId) || 
                                     isParentOf(resource.data.toId));
      allow create: if isAuthenticated();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated() && (resource.data.isPublic == true || isGroupMember(resource.data));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isGroupAdmin(resource.data) || 
        (resource.data.members.hasAny([request.auth.uid]) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'pendingMembers', 'name', 'imageURL']) &&
         (!request.resource.data.members.hasAny([request.auth.uid]) || request.resource.data.members.size() >= resource.data.members.size())
        ) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'pendingMembers']) && 
           (resource.data.get('pendingMembers', []).hasAny([request.auth.uid]) || 
            (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'parent' && 
             resource.data.get('pendingMembers', []).hasAny(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('linkedKids', []))))
        )
      );
      allow delete: if isGroupAdmin(resource.data);

      match /events/{eventId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
      
      match /sessions/{sessionId} {
        allow read, create, update, delete: if isAuthenticated();
      }
      
      match /games/{gameId} {
        allow read, create, update, delete: if isAuthenticated();
      }
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || 
        isParentOf(resource.data.userId) || 
        resource.data.get('parentId', '') == request.auth.uid ||
        // Allow the person who sent the invite to delete it
        resource.data.get('data', {}).get('invitedBy', '') == request.auth.uid ||
        (resource.data.get('data', {}).get('invitedBy', '') != '' && isParentOf(resource.data.data.invitedBy)) ||
        // Allow team administrators to read and delete notifications for their group
        (resource.data.get('data', {}).get('groupId', '') != '' && isGroupAdminById(resource.data.data.groupId))
      );
      allow create: if isAuthenticated();
    }

    match /approvals/{approvalId} {
      allow read, update, delete: if isAuthenticated() && 
                                    (resource.data.childId == request.auth.uid || 
                                     resource.data.parentId == request.auth.uid || 
                                     isParentOf(resource.data.childId));
      allow create: if isAuthenticated();
    }
  }
}
