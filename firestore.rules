rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    //Relational Helpers
    function getMyDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isParent() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'parent';
    }

    function isParentOf(childId) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('linkedKids', []).hasAny([childId])) ||
        (get(/databases/$(database)/documents/users/$(childId)).data.get('parentId', '') == request.auth.uid)
      );
    }

    function isParentOfAnyMember(members) {
      return isParent() && getMyDoc().get('linkedKids', []).hasAny(members);
    }

    function friendsAdded() {
      return incoming().get('friends', []).toSet().difference(existing().get('friends', []).toSet());
    }

    function friendsRemoved() {
      return existing().get('friends', []).toSet().difference(incoming().get('friends', []).toSet());
    }

    function isSingleFriendAddition() {
      return friendsAdded().size() == 1 &&
             friendsRemoved().size() == 0 &&
             incoming().get('friends', []).size() == existing().get('friends', []).size() + 1 &&
             incoming().get('friends', []).toSet().hasAll(existing().get('friends', []));
    }

    function isSingleFriendRemoval() {
      return friendsAdded().size() == 0 &&
             friendsRemoved().size() == 1 &&
             incoming().get('friends', []).size() + 1 == existing().get('friends', []).size() &&
             existing().get('friends', []).toSet().hasAll(incoming().get('friends', []));
    }

    function isFriendNoop() {
      return friendsAdded().size() == 0 &&
             friendsRemoved().size() == 0;
    }

    function groupMembersAdded() {
      return incoming().get('members', []).toSet().difference(existing().get('members', []).toSet());
    }

    function groupMembersRemoved() {
      return existing().get('members', []).toSet().difference(incoming().get('members', []).toSet());
    }

    function groupPendingAdded() {
      return incoming().get('pendingMembers', []).toSet().difference(existing().get('pendingMembers', []).toSet());
    }

    function groupPendingRemoved() {
      return existing().get('pendingMembers', []).toSet().difference(incoming().get('pendingMembers', []).toSet());
    }

    function groupParentIdsAdded() {
      return incoming().get('parentIds', []).toSet().difference(existing().get('parentIds', []).toSet());
    }

    function groupParentIdsRemoved() {
      return existing().get('parentIds', []).toSet().difference(incoming().get('parentIds', []).toSet());
    }

    function isTeamInviteResolutionUpdate() {
     return incoming().diff(existing()).affectedKeys().hasOnly(['members', 'pendingMembers', 'parentIds']) &&
         incoming().get('members', []) is list &&
         existing().get('members', []) is list &&
         incoming().get('pendingMembers', []) is list &&
         existing().get('pendingMembers', []) is list &&
         incoming().get('parentIds', []) is list &&
         existing().get('parentIds', []) is list &&
         groupMembersRemoved().size() == 0 &&
         groupPendingAdded().size() == 0 &&
         groupParentIdsRemoved().size() == 0 &&
         groupPendingRemoved().size() == 1 &&
         // Allow the invited user themselves, OR a parent acting on behalf of their linked kid.
         // Kids don't have their own Firebase Auth accounts, so request.auth.uid is the parent's uid
         // while the kid's doc id sits in pendingMembers.
         (
           groupPendingRemoved().hasAny([request.auth.uid]) ||
           groupPendingRemoved().hasAny(getMyDoc().get('linkedKids', []))
         ) &&
         groupMembersAdded().size() <= 1 &&
         groupParentIdsAdded().size() <= 1 &&
         (
           // reject
           groupMembersAdded().size() == 0 ||
           // accept: the member added must be the same pending user being removed
           (
             groupMembersAdded().size() == 1 &&
             groupPendingRemoved().hasAll(groupMembersAdded())
           )
         );
}

    function isGroupMember(groupId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/groups/$(groupId)).data.get('members', []).hasAny([request.auth.uid]) ||
        get(/databases/$(database)/documents/groups/$(groupId)).data.get('parentIds', []).hasAny([request.auth.uid]) ||
        isParentOfAnyMember(get(/databases/$(database)/documents/groups/$(groupId)).data.get('members', []))
      );
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/groups/$(groupId)).data.get('ownerId', '') == request.auth.uid ||
        get(/databases/$(database)/documents/groups/$(groupId)).data.get('adminIds', []).hasAny([request.auth.uid]) ||
        isParentOf(get(/databases/$(database)/documents/groups/$(groupId)).data.get('ownerId', ''))
      );
    }

    // Validation Blueprint for Session
    function isValidSession(data) {
      let hasScheduleDetails = data.keys().hasAll(['startTime', 'duration']) &&
                               data.startTime is timestamp &&
                               data.duration is number &&
                               data.duration > 0;
      let isProposal = data.status == 'proposed';

      return data.keys().hasAll(['gameName', 'status', 'proposedBy']) &&
             data.gameName is string && data.gameName.size() <= 200 &&
             data.status in ['proposed', 'scheduled', 'ongoing', 'completed', 'cancelled'] &&
             data.proposedBy is string &&
             (!data.keys().hasAny(['gameId']) || data.gameId is string) &&
             (!data.keys().hasAny(['groupId']) || data.groupId is string) &&
             (!data.keys().hasAny(['gameImage']) || data.gameImage is string) &&
             (!data.keys().hasAny(['responses']) || data.responses is map) &&
             (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp) &&
             (!data.keys().hasAny(['endTime']) || data.endTime is timestamp) &&
             (isProposal || hasScheduleDetails);
    }

    function isValidGroupGame(data) {
      return data.keys().hasAll(['name', 'image', 'description', 'platforms', 'genres', 'addedBy']) &&
             data.name is string && data.name.size() <= 200 &&
             data.image is string &&
             data.description is string &&
             data.platforms is list &&
             data.genres is list &&
             (data.addedBy == request.auth.uid || isParentOf(data.addedBy)) &&
             (!data.keys().hasAny(['addedByName']) || data.addedByName is string) &&
             (!data.keys().hasAny(['slug']) || data.slug is string) &&
             (!data.keys().hasAny(['rating']) || data.rating is number) &&
             (!data.keys().hasAny(['releaseDate']) || data.releaseDate is string) &&
             (!data.keys().hasAny(['isChildFriendly']) || data.isChildFriendly is bool) &&
             (!data.keys().hasAny(['minAge']) || data.minAge == null || data.minAge is number) &&
             (!data.keys().hasAny(['teamGoals']) || data.teamGoals is list) &&
             (!data.keys().hasAny(['teamNotes']) || data.teamNotes is string) &&
             (!data.keys().hasAny(['addedAt']) || data.addedAt is timestamp);
    }

    function isValidGroupGameCollaborationUpdate(data) {
      return (!data.keys().hasAny(['teamGoals']) || data.teamGoals is list) &&
             (!data.keys().hasAny(['teamNotes']) || data.teamNotes is string);
    }

    function isSingleFriendAdditionOfCaller() {
  return friendsAdded().size() == 1 &&
         friendsRemoved().size() == 0 &&
         friendsAdded().hasAny([request.auth.uid]) &&
         incoming().get('friends', []) is list;
}

function isSingleFriendRemovalOfCaller() {
  return friendsAdded().size() == 0 &&
         friendsRemoved().size() == 1 &&
         friendsRemoved().hasAny([request.auth.uid]) &&
         incoming().get('friends', []) is list;
}

// Allows a parent to add/remove one of their linked kids as a friend on another user's doc.
// This is needed because kids don't have their own Firebase Auth accounts — the parent's
// auth.uid is used, so isSingleFriendAdditionOfCaller() alone is not enough cross-account.
function isSingleFriendAdditionOfLinkedKid() {
  return friendsAdded().size() == 1 &&
         friendsRemoved().size() == 0 &&
         friendsAdded().hasAny(getMyDoc().get('linkedKids', [])) &&
         incoming().get('friends', []) is list;
}

function isSingleFriendRemovalOfLinkedKid() {
  return friendsAdded().size() == 0 &&
         friendsRemoved().size() == 1 &&
         friendsRemoved().hasAny(getMyDoc().get('linkedKids', [])) &&
         incoming().get('friends', []) is list;
}

function isFriendLinkUpdateForCaller(userId) {
  return incoming().diff(existing()).affectedKeys().hasOnly(['friends']) &&
         incoming().get('friends', []) is list &&
         (
           isSingleFriendAdditionOfCaller() ||
           isSingleFriendRemovalOfCaller() ||
           isSingleFriendAdditionOfLinkedKid() ||
           isSingleFriendRemovalOfLinkedKid()
         );
}

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.uid == request.auth.uid || 
        resource.data.parentId == request.auth.uid
      );
      
      allow create: if isSignedIn() && (isOwner(userId) || incoming().get('parentId', '') == request.auth.uid);
      allow update: if isSignedIn() && (
        isOwner(userId) || 
        isParentOf(userId) || 
        (existing().get('parentId', '') == request.auth.uid) ||
        (incoming().get('parentId', '') == request.auth.uid) ||
        // Friend relationships work cross-account: only one friend id can be added or removed.
        isFriendLinkUpdateForCaller(userId)
      );
      allow delete: if isSignedIn() && (isOwner(userId) || isParentOf(userId));
    }

    match /users_public/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(userId) || incoming().get('parentId', '') == request.auth.uid);
      allow update: if isSignedIn() && (
        isOwner(userId) || 
        isParentOf(userId) || 
        (existing().get('parentId', '') == request.auth.uid) ||
        (incoming().get('parentId', '') == request.auth.uid)
      );
      allow delete: if isSignedIn() && (isOwner(userId) || isParentOf(userId));
    }

    match /friendRequests/{requestId} {
      allow get: if isSignedIn() && (
        resource.data.fromId == request.auth.uid || 
        resource.data.toId == request.auth.uid ||
        resource.data.get('fromParentId', '') == request.auth.uid ||
        resource.data.get('toParentId', '') == request.auth.uid ||
        isParentOf(resource.data.fromId) ||
        isParentOf(resource.data.toId)
      );
      allow list: if isSignedIn() && (
        resource.data.fromId == request.auth.uid || 
        resource.data.toId == request.auth.uid ||
        resource.data.get('fromParentId', '') == request.auth.uid ||
        resource.data.get('toParentId', '') == request.auth.uid ||
        isParentOf(resource.data.fromId) ||
        isParentOf(resource.data.toId)
      );
      allow create: if isSignedIn() && (
        incoming().fromId == request.auth.uid || 
        incoming().get('fromParentId', '') == request.auth.uid ||
        isParentOf(incoming().fromId)
      );
      allow update: if isSignedIn() && (
        // Sender or receiver can update
        (resource.data.fromId == request.auth.uid || 
         resource.data.toId == request.auth.uid ||
         resource.data.get('fromParentId', '') == request.auth.uid ||
         resource.data.get('toParentId', '') == request.auth.uid ||
         isParentOf(resource.data.fromId) ||
         isParentOf(resource.data.toId)) &&
        // Only allow status changes from pending to accepted/rejected
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().get('status', '') in ['accepted', 'rejected'] &&
        existing().get('status', '') == 'pending'
      );
      allow delete: if isSignedIn() && (
        resource.data.fromId == request.auth.uid ||
        resource.data.toId == request.auth.uid ||
        resource.data.get('fromParentId', '') == request.auth.uid ||
        resource.data.get('toParentId', '') == request.auth.uid ||
        isParentOf(resource.data.fromId) ||
        isParentOf(resource.data.toId)
      );
    }

    match /groups/{groupId} {
      allow get: if isSignedIn() && (
        resource.data.members.hasAny([request.auth.uid]) ||
        resource.data.get('pendingMembers', []).hasAny([request.auth.uid]) ||
        resource.data.get('parentIds', []).hasAny([request.auth.uid]) ||
        isParentOfAnyMember(resource.data.members) ||
        isParentOfAnyMember(resource.data.get('pendingMembers', []))
      );

      allow list: if isSignedIn() && (
        resource.data.members.hasAny([request.auth.uid]) || 
        resource.data.get('parentIds', []).hasAny([request.auth.uid]) ||
        isParent()
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.members.hasAny([request.auth.uid]) ||
        isGroupAdmin(groupId) ||
        // Team invitations work cross-account: resolve exactly one pending member.
        isTeamInviteResolutionUpdate()
      );
      allow delete: if isSignedIn() && isGroupAdmin(groupId);

      match /sessions/{sessionId} {
        allow read: if isGroupMember(groupId);
        allow create, update: if isGroupMember(groupId) && isValidSession(incoming());
        allow delete: if isGroupAdmin(groupId);
      }

      match /games/{gameId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && isValidGroupGame(incoming());
        allow update: if isGroupAdmin(groupId) || (
          isGroupMember(groupId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['teamGoals', 'teamNotes']) &&
          isValidGroupGameCollaborationUpdate(incoming())
        );
        allow delete: if isGroupAdmin(groupId);
      }

      match /events/{eventId} {
        allow read, create: if isGroupMember(groupId) || resource.data.get('pendingMembers', []).hasAny([request.auth.uid]);
      }
    }

    match /notifications/{notificationId} {
      allow get, list, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.get('parentId', '') == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('linkedKids', []).hasAny([resource.data.userId]))
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.get('parentId', '') == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('linkedKids', []).hasAny([resource.data.userId]))
      ) && incoming().diff(existing()).affectedKeys().hasOnly(['read', 'handled', 'decision']);
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (resource.data.get('childId', '') == request.auth.uid || 
                                      resource.data.get('parentId', '') == request.auth.uid ||
                                      isParentOf(resource.data.get('childId', '')));
      allow create: if isSignedIn() && (incoming().get('childId', '') == request.auth.uid || isParentOf(incoming().get('childId', '')));
      allow update, delete: if isParent() && resource.data.get('parentId', '') == request.auth.uid;
    }

    match /approvals/{approvalId} {
      allow read: if isSignedIn() && (resource.data.childId == request.auth.uid || resource.data.parentId == request.auth.uid);
      allow create: if isSignedIn() && incoming().childId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.childId == request.auth.uid || resource.data.parentId == request.auth.uid);
      allow delete: if isParent() && resource.data.parentId == request.auth.uid;
    }
  }
}
